<UserControl x:Class="AcademyJornal.UI.Views.ChartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
              xmlns:vm="clr-namespace:AcademyJornal.UI.ViewModels"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:local="clr-namespace:AcademyJornal.UI.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"  Background="{DynamicResource BackgroundBrush}">
    
        <UserControl.DataContext>
            <vm:ChartViewModel/>
        </UserControl.DataContext>

        <UserControl.Resources>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </UserControl.Resources>

        <Grid Margin="28,24" Background="{DynamicResource BackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0"
                   Text="📈 Диаграммы успеваемости"
                   FontSize="22" FontWeight="Bold"
                   Foreground="{DynamicResource AccentPurpleLightBrush}"
                   Margin="0,0,0,16"/>

            <!-- Фильтры -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="Группа:" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,10,0"/>
                <ComboBox ItemsSource="{Binding Groups}"
                      SelectedItem="{Binding SelectedGroup}"
                      Style="{DynamicResource ComboStyle}"
                      Width="140" Margin="0,0,24,0"/>

                <TextBlock Text="Модуль:" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,10,0"/>
                <ComboBox ItemsSource="{Binding Modules}"
                      SelectedItem="{Binding SelectedModule}"
                      DisplayMemberPath="Name"
                      Style="{DynamicResource ComboStyle}"
                      Width="180"/>
            </StackPanel>

            <!-- Ошибка -->
            <Border Grid.Row="2"
                Background="#33E24B4A" BorderBrush="#E24B4A"
                BorderThickness="1" CornerRadius="8"
                Padding="12,8" Margin="0,0,0,8"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#E24B4A" FontSize="13"/>
            </Border>

            <!-- Статистика -->
            <Border Grid.Row="3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="10"
                Padding="16,10" Margin="0,0,0,20">
                <TextBlock Text="{Binding StatsText}"
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Border>

            <!-- Диаграммы -->
            <Grid Grid.Row="4" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Столбчатая -->
                <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Средние баллы студентов"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>
                        <lvc:CartesianChart Grid.Row="1"
                                        Series="{Binding BarSeries}"
                                        XAxes="{Binding BarXAxes}"
                                        YAxes="{Binding BarYAxes}"
                                        TooltipPosition="Hidden"/>
                    </Grid>
                </Border>

                <!-- Круговая -->
                <Border Grid.Column="2"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Распределение по уровням"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>
                        <lvc:PieChart Grid.Row="1"
                                  Series="{Binding PieSeries}"
                                  TooltipPosition="Hidden"/>
                      
                        <StackPanel Grid.Row="2" Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <Border Width="12" Height="12" Background="#7F77DD" CornerRadius="2" Margin="0,0,6,0"/>
                                <TextBlock Text="Отлично (9-12)" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <Border Width="12" Height="12" Background="#1D9E75" CornerRadius="2" Margin="0,0,6,0"/>
                                <TextBlock Text="Хорошо (7-8)" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <Border Width="12" Height="12" Background="#EF9F27" CornerRadius="2" Margin="0,0,6,0"/>
                                <TextBlock Text="Средне (5-6)" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <Border Width="12" Height="12" Background="#E24B4A" CornerRadius="2" Margin="0,0,6,0"/>
                                <TextBlock Text="Слабо (&lt;5)" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
</UserControl>


