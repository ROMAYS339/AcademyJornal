<UserControl x:Class="AcademyJornal.UI.Views.ReviewsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AcademyJornal.UI.ViewModels"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.DataContext>
        <vm:ReviewViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0"
                   Text="💬 Генератор отзывов"
                   FontSize="22" FontWeight="Bold"
                   Foreground="{DynamicResource AccentPurpleLightBrush}"
                   Margin="0,0,0,20"/>

        <!-- Форма выбора -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="12"
                Padding="20" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Студент -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Студент" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Students}"
                              SelectedItem="{Binding SelectedStudent}"
                              DisplayMemberPath="FullName"
                              />
                </StackPanel>

                <!-- Модуль -->
                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                    <TextBlock Text="Модуль" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Modules}"
                              SelectedItem="{Binding SelectedModule}"
                              DisplayMemberPath="Name"
                              />
                </StackPanel>

                <!-- Кнопка -->
                <Button Grid.Column="2"
                        Content="✨  Сгенерировать"
                        Style="{DynamicResource PrimaryButton}"
                        VerticalAlignment="Bottom"
                        Command="{Binding GenerateCommand}"/>
            </Grid>
        </Border>

        <!-- Ошибка -->
        <Border Grid.Row="2"
                Background="#33E24B4A"
                BorderBrush="#E24B4A"
                BorderThickness="1" CornerRadius="8"
                Padding="12,8" Margin="0,0,0,12"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#E24B4A" FontSize="13"/>
        </Border>

        <!-- Список отзывов -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Reviews}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="12"
                                Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <!-- Шапка карточки -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="👤 " FontSize="14"/>
                                    <TextBlock Text="{Binding StudentName}"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding ModuleName}"
                                               FontSize="13" Margin="10,2,0,0"
                                               Foreground="{DynamicResource AccentPurpleLightBrush}"/>
                                    <TextBlock Text="{Binding GeneratedAt, StringFormat='   {0}'}"
                                               FontSize="11" Margin="8,3,0,0"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <!-- Редактируемый текст отзыва -->
                                <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource InputBox}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="100"
                                         VerticalScrollBarVisibility="Auto"/>

                                <!-- Кнопки -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Content="📋  Копировать"
                                            Style="{DynamicResource PrimaryButton}"
                                            Padding="12,6"
                                            Command="{Binding DataContext.CopyCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="💾  Сохранить в БД"
                                            Style="{DynamicResource PrimaryButton}"
                                            Padding="12,6" Margin="8,0,0,0"
                                            Command="{Binding DataContext.SaveCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="✕  Удалить"
                                            Style="{DynamicResource SecondaryButton}"
                                            Padding="12,6" Margin="8,0,0,0"
                                            Command="{Binding DataContext.DeleteCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
