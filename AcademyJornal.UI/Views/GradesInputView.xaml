<UserControl x:Class="AcademyJornal.UI.Views.GradesInputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AcademyJornal.UI.ViewModels"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.DataContext>
        <vm:GradesInputViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24">

            <!-- Заголовок -->
            <TextBlock Text="📝 Оценки и парсинг"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource AccentPurpleLightBrush}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Введите данные в формате: «Имя Фамилия оценка1 оценка2 ...» — по одному студенту на строку."
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,20" TextWrapping="Wrap"/>

            <!-- Панель ввода -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12"
                    Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Текстовый ввод оценок"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,10"/>

                    <TextBox Text="{Binding RawInput, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource InputBox}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="140"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="13"
                             Margin="0,0,0,12"/>

                    <!-- Фильтры и кнопки -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Модуль" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Modules}"
                                      SelectedItem="{Binding SelectedModule}"
                                      DisplayMemberPath="Name"
                                      />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="Тип оценки" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding GradeTypes}"
                                      SelectedItem="{Binding SelectedGradeType}"
                                      />
                        </StackPanel>

                        <Button Grid.Column="2"
                                Content="🔍  Распарсить"
                                Style="{DynamicResource PrimaryButton}"
                                VerticalAlignment="Bottom"
                                Margin="0,0,8,0"
                                Command="{Binding ParseCommand}"/>

                        <Button Grid.Column="3"
                                Content="💾  Сохранить"
                                Style="{DynamicResource PrimaryButton}"
                                VerticalAlignment="Bottom"
                                Margin="0,0,8,0"
                                Command="{Binding SaveCommand}"/>

                        <Button Grid.Column="4"
                                Content="✕  Очистить"
                                Style="{DynamicResource SecondaryButton}"
                                VerticalAlignment="Bottom"
                                Command="{Binding ClearCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Ошибка -->
            <Border Background="#33E24B4A" BorderBrush="#E24B4A"
                    BorderThickness="1" CornerRadius="8"
                    Padding="12,8" Margin="0,0,0,8"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#E24B4A" FontSize="13" TextWrapping="Wrap"/>
            </Border>

            <!-- Успех -->
            <Border Background="#221D9E75" BorderBrush="#1D9E75"
                    BorderThickness="1" CornerRadius="8"
                    Padding="12,8" Margin="0,0,0,8"
                    Visibility="{Binding SaveSuccess, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#1D9E75" FontSize="13" TextWrapping="Wrap"/>
            </Border>

            <!-- Статус (только когда нет ошибок и нет успеха) -->
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,12" TextWrapping="Wrap"
                       Visibility="{Binding HasParsed, Converter={StaticResource BoolToVis}}"/>

            <!-- Таблица результатов парсинга -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12"
                    Padding="0,0,0,8"
                    Visibility="{Binding HasParsed, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <!-- Заголовок -->
                    <Border Background="{DynamicResource SurfaceAltBrush}"
                            CornerRadius="12,12,0,0" Padding="16,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Студент"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="Оценки"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="2" Text="Среднее"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                    </Border>
                    <!-- Строки -->
                    <ItemsControl ItemsSource="{Binding ParsedRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16,10"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding StudentName}"
                                                   FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Grades}"
                                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontFamily="Consolas"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Average}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentPurpleLightBrush}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Подсказка формата -->
            <Border Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="16,12" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="📌 Формат ввода"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                               Text="Каждая строка: «Имя Фамилия оценка1 оценка2 оценка3 ...»&#x0a;Оценки от 0 до 12. 0 — пропуск / несдача.&#x0a;Пример:&#x0a;Анна Петрова 11 10 12 9&#x0a;Иван Сидоров 7 8 9 0 8&#x0a;Мария Козлова 6 7 0 6"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
