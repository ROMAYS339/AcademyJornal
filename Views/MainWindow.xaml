<Window x:Class="AcademyJornal.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Academy Jornal" 
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0F">

    <Window.Resources>
        <!-- Цвета -->
        <SolidColorBrush x:Key="PrimaryPink" Color="#FF1493"/>
        <SolidColorBrush x:Key="PrimaryPurple" Color="#6C3B9A"/>
        <SolidColorBrush x:Key="DarkPurple" Color="#2D1B3D"/>

        <LinearGradientBrush x:Key="MainBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0A0A0F" Offset="0"/>
            <GradientStop Color="#2D1B3D" Offset="1"/>
        </LinearGradientBrush>

        <!-- Стиль для кнопок меню -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D1B3D"/>
                                <Setter Property="Foreground" Value="#FF1493"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для обычных кнопок -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Background" Value="#FF1493"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6C3B9A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource MainBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#1A0A2E">
            <Grid>
                <TextBlock Text="ACADEMY JORNAL" 
                          FontSize="18" 
                          FontWeight="Bold"
                          Foreground="#FF1493"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center"
                            Margin="0,0,10,0">
                    <Button x:Name="MinimizeButton" Content="─" Width="30" Height="30"
                            Background="Transparent" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="MinimizeButton_Click"/>
                    <Button x:Name="MaximizeButton" Content="□" Width="30" Height="30"
                            Background="Transparent" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Margin="5,0"
                            Click="MaximizeButton_Click"/>
                    <Button x:Name="CloseButton" Content="✕" Width="30" Height="30"
                            Background="Transparent" Foreground="#FF1493"
                            BorderThickness="0" Cursor="Hand"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левое меню -->
            <Border Grid.Column="0" Background="#1A0A2E" BorderBrush="#2D1B3D" BorderThickness="0,0,1,0">
                <StackPanel Margin="10">
                    <Button x:Name="DashboardBtn" Content="📊 Главная" Style="{StaticResource MenuButton}" Margin="0,5"/>
                    <Button x:Name="StudentsBtn" Content="👨‍🎓 Студенты" Style="{StaticResource MenuButton}" Margin="0,5"/>
                    <Button x:Name="CoursesBtn" Content="📚 Курсы" Style="{StaticResource MenuButton}" Margin="0,5"/>
                    <Button x:Name="GradesBtn" Content="⭐ Оценки" Style="{StaticResource MenuButton}" Margin="0,5"/>
                    <Button x:Name="ScheduleBtn" Content="📅 Расписание" Style="{StaticResource MenuButton}" Margin="0,5"/>

                    <Border Background="#2D1B3D" Height="1" Margin="10,20,10,20"/>

                    <Button x:Name="SettingsBtn" Content="⚙️ Настройки" Style="{StaticResource MenuButton}" Margin="0,5"/>
                </StackPanel>
            </Border>

            <!-- Область контента (здесь будут меняться страницы) -->
            <Border Grid.Column="1" Background="Transparent" Padding="20">
                <Border Background="#2D1B3D" CornerRadius="10" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Добро пожаловать!" 
                                   FontSize="24" 
                                   FontWeight="Bold"
                                   Foreground="#FF1493"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Academy Jornal - система управления академическим журналом" 
                                   FontSize="14"
                                   Foreground="#CCCCCC"
                                   Margin="0,0,0,30"/>

                        <Border Background="#1A0A2E" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <TextBlock Text="✅ Здесь будет отображаться основное содержимое" 
                                       Foreground="White"/>
                        </Border>

                        <Border Background="#1A0A2E" CornerRadius="8" Padding="15">
                            <TextBlock Text="📌 Используйте меню слева для навигации" 
                                       Foreground="White"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Window>